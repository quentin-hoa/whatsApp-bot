[Unit]
Description=WhatsApp bot (notifications + Claude Code usage watchdog)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=<YOUR_USERNAME>
WorkingDirectory=/home/<YOUR_USERNAME>/whatsapp-bot
ExecStart=/usr/bin/node /home/<YOUR_USERNAME>/whatsapp-bot/bot.js
Restart=always
RestartSec=10
StandardOutput=append:/home/<YOUR_USERNAME>/whatsapp-bot/bot.log
StandardError=append:/home/<YOUR_USERNAME>/whatsapp-bot/bot.log

[Install]
WantedBy=multi-user.target
